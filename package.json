{
  "name": "mobile",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:apk": "expo prebuild --platform android --clean && cd android && ./gradlew assembleDebug && cd ..",
    "ios": "expo run:ios",
    "ios:simulator": "expo run:ios --device",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build:all": "eas build --platform all",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "test:maestro": "maestro test ../maestro-test/main.yaml",
    "test:maestro:all": "maestro test ../maestro-test/main.yaml",
    "test:maestro:auth": "maestro test ../maestro-test/flows/auth/_suite.yaml",
    "test:maestro:products": "maestro test ../maestro-test/flows/products/_suite.yaml",
    "test:maestro:search": "maestro test ../maestro-test/flows/search/_suite.yaml",
    "test:maestro:other": "maestro test ../maestro-test/flows/other/_suite.yaml",
    "test:maestro:protected": "maestro test ../maestro-test/flows/protected-pages.yaml"
  },
  "dependencies": {
    "@clerk/clerk-expo": "~2.0.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.7.9",
    "expo": "~54.0.25",
    "expo-auth-session": "~7.0.9",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-picker": "^17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.9",
    "expo-local-authentication": "~14.0.0",
    "expo-router": "~6.0.15",
    "expo-secure-store": "~14.0.0",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "nativewind": "^4.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
